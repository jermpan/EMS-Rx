function fmtNum(n) {
  if (n===null||isNaN(n)) return '—';
  if (n>=100) return Math.round(n).toString();
  if (n>=10) return parseFloat(n.toFixed(1)).toString();
  return parseFloat(n.toFixed(3)).toString();
}

function renderMeds() {
  const c = document.getElementById('med-list-render');
  if (!appData.meds.length) { c.innerHTML='<div class="empty-state">NO MEDICATIONS CONFIGURED<br>Tap ADMIN → Add Medication</div>'; return; }

  c.innerHTML = appData.meds.map(med => {
    const isOpen = openCards.has(med.id);
    // Concentration selector
    let concHtml = '';
    if (med.concentrations && med.concentrations.length > 0) {
      concHtml = `<div class="conc-select-row"><label>CONC:</label><select class="conc-sel" id="conc-${med.id}" onchange="renderMeds()">${med.concentrations.map((c2,i)=>`<option value="${i}">${c2.label}</option>`).join('')}</select></div>`;
    }

    function doseBlock(type) {
      const dose = type==='adult' ? med.adult : med.peds;
      if (!dose) return '';
      const selEl = document.getElementById(`conc-${med.id}`);
      const concIdx = selEl ? parseInt(selEl.value)||0 : 0;
      const conc = med.concentrations && med.concentrations[concIdx];
      const mgPerMl = conc ? conc.mgPerMl : null;

      let mgStr='', mlStr='', fixedStr='', hintStr='', warnHtml='', formula='';
      if (dose.mgkg && patientKg) {
        const raw = dose.mgkg * patientKg;
        const maxD = parseFloat(dose.maxDose);
        const capped = (!isNaN(maxD) && maxD > 0) ? Math.min(raw, maxD) : raw;
        const hit = (!isNaN(maxD) && maxD > 0) && raw > maxD;
        mgStr = `<span class="dose-mg">${fmtNum(capped)} mg</span>`;
        formula = `${dose.mgkg} mg/kg × ${patientKg} kg${hit?' (MAX)':''}`;
        if (mgPerMl) mlStr = `<span class="dose-ml">${fmtNum(capped/mgPerMl)} mL</span>`;
        if (hit) warnHtml = `<div class="max-warn visible">⚠ MAX DOSE REACHED — capped at ${maxD} mg per protocol</div>`;
      } else if (dose.fixed) {
        fixedStr = `<span class="dose-fixed">${dose.fixed}</span>`;
        formula = 'Fixed dose';
      } else if (!patientKg && dose.mgkg) {
        hintStr = `<span class="dose-hint">Enter patient weight ↑</span>`;
        formula = `${dose.mgkg} mg/kg (need weight)`;
      }

      return `<div class="dose-row">
        <div class="dose-info">
          <div class="dose-title">${dose.initLabel||type}</div>
          <div class="dose-formula">${formula}${dose.route ? ' · '+dose.route : ''}</div>
          ${dose.repeat ? `<div class="dose-repeat">↻ ${dose.repeat}</div>` : ''}
        </div>
        <div class="dose-result">${mgStr}${mlStr}${fixedStr}${hintStr}</div>
      </div>${warnHtml}`;
    }

    return `<div class="med-card${isOpen?' open':''}" id="mc-${med.id}">
      <div class="med-header" onclick="toggleCard(${med.id})">
        <div class="med-pill" style="background:${med.color||'#888'};box-shadow:0 0 6px ${med.color||'#888'}55;"></div>
        <div class="med-name-wrap">
          <div class="med-name" style="color:${med.color||'#fff'}">${med.name}</div>
          <div class="med-class">${med.drugClass||''}</div>
        </div>
        <div class="med-chevron">▾</div>
      </div>
      <div class="med-body">
        ${concHtml}
        <div class="dose-section"><div class="dose-section-title">ADULT</div>${doseBlock('adult')}</div>
        <div class="dose-section" style="margin-top:8px;"><div class="dose-section-title">PEDIATRIC</div>${doseBlock('peds')}</div>
        ${med.notes?`<div class="med-notes"><b>⚠ CLINICAL NOTES</b>${med.notes}</div>`:''}
      </div>
    </div>`;
  }).join('');
}

function toggleCard(id) {
  if (openCards.has(id)) openCards.delete(id); else openCards.add(id);
  renderMeds();
}

// ═══════════════════════════ ADMIN ═══════════════════════════
function openAdmin() {
  document.getElementById('admin-modal').classList.add('open');
  document.getElementById('pw-gate-section').style.display='';
  document.getElementById('admin-panel-inner').classList.remove('show');
  document.getElementById('pw-input').value='';
  document.getElementById('pw-err').style.display='none';
}
function closeAdmin() { document.getElementById('admin-modal').classList.remove('open'); }

function checkPW() {
  if (document.getElementById('pw-input').value === appData.pw) {
    document.getElementById('pw-gate-section').style.display='none';
    document.getElementById('admin-panel-inner').classList.add('show');
    renderAdminList();
    document.getElementById('dept-name').value = appData.dept||'';
    document.getElementById('new-pw').value='';
  } else {
    document.getElementById('pw-err').style.display='block';
    document.getElementById('pw-input').value='';
  }
}

function adminTab(tab, btn) {
  document.querySelectorAll('.admin-tab').forEach(t=>t.classList.remove('active'));
  document.querySelectorAll('.admin-section').forEach(s=>s.classList.remove('active'));
  if(btn) btn.classList.add('active');
  document.getElementById('asec-'+tab).classList.add('active');
}

function renderAdminList() {
  const c = document.getElementById('admin-med-list');
  if (!appData.meds.length) { c.innerHTML='<div class="empty-state" style="padding:14px 0;">No medications. Add one below.</div>'; return; }
  c.innerHTML = appData.meds.map(m=>`
    <div class="med-list-item">
      <div class="med-list-dot" style="background:${m.color||'#888'};"></div>
      <div style="flex:1;min-width:0;">
        <div class="med-list-name" style="color:${m.color||'#fff'}">${m.name}</div>
        <div class="med-list-class">${m.drugClass||''}</div>
      </div>
      <div class="med-list-actions">
        <button class="med-list-btn edit" onclick="openMedEditor(${m.id})">Edit</button>
        <button class="med-list-btn del" onclick="deleteMed(${m.id})">✕</button>
      </div>
    </div>`).join('');
}

function deleteMed(id) {
  if (!confirm('Delete this medication?')) return;
  appData.meds = appData.meds.filter(m=>m.id!==id);
  saveData(); renderAdminList(); renderMeds();
}

function saveSettings() {
  const np = document.getElementById('new-pw').value;
  if (np && np.length>=4) appData.pw=np;
  appData.dept = document.getElementById('dept-name').value.trim();
  saveData(); updateDeptDisplay();
  alert('Settings saved!');
}

function resetToDefaults() {
  if (!confirm('Reset ALL data to defaults? Cannot be undone.')) return;
  appData = { meds: JSON.parse(JSON.stringify(DEFAULT_MEDS)), pw: DEFAULT_PW, dept: '' };
  saveData(); renderAdminList(); renderMeds(); updateDeptDisplay();
  alert('Reset complete.');
}

