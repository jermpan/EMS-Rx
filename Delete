  const lbsEl = document.getElementById('d-lbs'), kgEl = document.getElementById('d-kg');
  if (source === 'lbs') {
    const v = parseFloat(lbsEl.value);
    if (!isNaN(v) && v > 0) { patientKg = +(v/2.2046).toFixed(1); kgEl.value = patientKg; }
    else { patientKg = null; kgEl.value = ''; }
