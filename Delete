<hi!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<link rel="manifest" href="./manifest.json">
<link rel="apple-touch-icon" href="./icon-192.png">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="EMS Rx">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="EMS Rx">
<meta name="theme-color" content="#060d1a">
<title>EMS Dosage Calculator</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;500;600;700;800&family=Share+Tech+Mono&family=Barlow:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #060d1a;
  --surface: #0b1628;
  --surface2: #0f1e36;
  --surface3: #162440;
  --border: #1a3055;
  --border2: #234070;
  --accent: #e83b3b;
  --accent-glow: rgba(232,59,59,0.3);
  --blue: #2196f3;
  --blue-dim: rgba(33,150,243,0.12);
  --green: #00c896;
  --yellow: #f5a623;
  --text: #dde8f5;
  --text-dim: #6a8aaa;
  --text-muted: #2e4a6a;
  --mono: 'Share Tech Mono', monospace;
  --display: 'Barlow Condensed', sans-serif;
  --body: 'Barlow', sans-serif;
}
* { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }
body { font-family: var(--body); background: var(--bg); color: var(--text); min-height: 100vh; overscroll-behavior: none; }
body::after { content:''; position:fixed; inset:0; background: repeating-linear-gradient(0deg,transparent,transparent 3px,rgba(0,0,0,0.04) 3px,rgba(0,0,0,0.04) 4px); pointer-events:none; z-index:9999; }

/* HEADER */
.app-header { position:sticky; top:0; z-index:500; background:rgba(6,13,26,0.97); border-bottom:1px solid var(–border); backdrop-filter:blur(16px); padding:0 14px; }
.header-row { display:flex; align-items:center; gap:10px; padding:11px 0 9px; }
.logo-cross { width:32px; height:32px; background:var(–accent); border-radius:7px; display:flex; align-items:center; justify-content:center; font-size:17px; box-shadow:0 0 14px var(–accent-glow); flex-shrink:0; }
.logo-text h1 { font-family:var(–display); font-size:1.25rem; font-weight:800; letter-spacing:3px; color:#fff; line-height:1; text-transform:uppercase; }
.logo-text p { font-family:var(–mono); font-size:0.52rem; color:var(–text-dim); letter-spacing:2px; margin-top:2px; }
.header-spacer { flex:1; }
.admin-btn { background:transparent; border:1px solid var(–border2); border-radius:7px; color:var(–text-dim); padding:6px 10px; font-family:var(–mono); font-size:0.62rem; letter-spacing:1px; cursor:pointer; }
.nav-tabs { display:flex; gap:2px; }
.nav-tab { flex:1; padding:8px 4px; background:transparent; border:none; border-bottom:2px solid transparent; color:var(–text-muted); font-family:var(–display); font-size:0.78rem; font-weight:700; letter-spacing:1.5px; text-transform:uppercase; cursor:pointer; transition:all 0.2s; }
.nav-tab.active { color:var(–accent); border-bottom-color:var(–accent); }

/* PAGES */
.page { display:none; padding:13px 13px 80px; }
.page.active { display:block; }

/* WEIGHT BAR */
.weight-bar { background:var(–surface); border:1px solid var(–border); border-radius:11px; padding:12px 13px; margin-bottom:12px; position:relative; overflow:hidden; }
.weight-bar::before { content:’’; position:absolute; top:0; left:0; right:0; height:2px; background:linear-gradient(90deg,var(–accent),transparent); }
.wb-label { font-family:var(–mono); font-size:0.58rem; color:var(–text-dim); letter-spacing:2px; margin-bottom:9px; }
.wb-inputs { display:grid; grid-template-columns:1fr 26px 1fr; gap:7px; align-items:end; }
.wb-field label { display:block; font-family:var(–mono); font-size:0.57rem; color:var(–text-dim); letter-spacing:1px; margin-bottom:4px; }
.field-inp { width:100%; background:var(–surface2); border:1px solid var(–border); border-radius:8px; padding:10px; color:var(–text); font-family:var(–mono); font-size:1rem; outline:none; -webkit-appearance:none; transition:border-color 0.2s; }
.field-inp:focus { border-color:var(–blue); }
.field-inp.kg-out { color:var(–blue); border-color:rgba(33,150,243,0.3); }
.field-inp::placeholder { color:var(–text-muted); }
.wb-arrow { text-align:center; color:var(–text-muted); font-size:0.9rem; padding-bottom:10px; }

/* DISCLAIMER */
.disclaimer { background:rgba(232,59,59,0.05); border:1px solid rgba(232,59,59,0.18); border-radius:8px; padding:9px 11px; margin-bottom:12px; display:flex; gap:7px; }
.disclaimer-text { font-size:0.65rem; color:#b07070; line-height:1.5; }

/* SECTION LABEL */
.section-label { font-family:var(–mono); font-size:0.58rem; color:var(–text-muted); letter-spacing:2.5px; text-transform:uppercase; padding:6px 1px 5px; display:flex; align-items:center; gap:8px; }
.section-label::after { content:’’; flex:1; height:1px; background:var(–border); }

/* MED CARDS */
.med-card { background:var(–surface); border:1px solid var(–border); border-radius:11px; margin-bottom:9px; overflow:hidden; transition:border-color 0.2s; }
.med-card.open { border-color:var(–border2); }
.med-header { display:flex; align-items:center; gap:10px; padding:12px 13px; cursor:pointer; user-select:none; }
.med-pill { width:9px; height:9px; border-radius:50%; flex-shrink:0; }
.med-name-wrap { flex:1; min-width:0; }
.med-name { font-family:var(–display); font-size:1rem; font-weight:700; letter-spacing:1px; line-height:1; }
.med-class { font-family:var(–mono); font-size:0.56rem; color:var(–text-dim); letter-spacing:1px; margin-top:2px; }
.med-chevron { font-size:0.75rem; color:var(–text-muted); transition:transform 0.25s; flex-shrink:0; }
.med-card.open .med-chevron { transform:rotate(180deg); color:var(–accent); }
.med-body { display:none; padding:0 13px 13px; border-top:1px solid var(–border); }
.med-card.open .med-body { display:block; }

/* CONCENTRATION */
.conc-select-row { display:flex; align-items:center; gap:7px; margin:9px 0 5px; }
.conc-select-row label { font-family:var(–mono); font-size:0.57rem; color:var(–text-dim); letter-spacing:1px; white-space:nowrap; }
.conc-sel { flex:1; background:var(–surface2); border:1px solid var(–border); border-radius:6px; padding:6px 9px; color:var(–blue); font-family:var(–mono); font-size:0.72rem; outline:none; -webkit-appearance:none; }

/* DOSE ROWS */
.dose-section { margin-top:7px; }
.dose-section-title { font-family:var(–mono); font-size:0.56rem; color:var(–text-muted); letter-spacing:2px; text-transform:uppercase; margin-bottom:5px; }
.dose-row { display:flex; justify-content:space-between; align-items:center; padding:7px 0; border-bottom:1px solid rgba(26,48,85,0.5); gap:8px; }
.dose-row:last-child { border-bottom:none; }
.dose-info { flex:1; min-width:0; }
.dose-title { font-family:var(–display); font-size:0.88rem; font-weight:600; letter-spacing:0.5px; color:var(–text); line-height:1.2; }
.dose-formula { font-family:var(–mono); font-size:0.58rem; color:var(–text-dim); margin-top:2px; }
.dose-repeat { font-family:var(–mono); font-size:0.58rem; color:var(–yellow); margin-top:1px; }
.dose-result { text-align:right; flex-shrink:0; }
.dose-mg { font-family:var(–mono); font-size:1rem; color:var(–green); font-weight:bold; display:block; line-height:1; }
.dose-ml { font-family:var(–mono); font-size:0.68rem; color:var(–blue); display:block; margin-top:2px; }
.dose-fixed { font-family:var(–mono); font-size:0.82rem; color:var(–yellow); display:block; }
.dose-hint { font-family:var(–mono); font-size:0.56rem; color:var(–text-muted); font-style:italic; }
.max-warn { display:none; background:rgba(232,59,59,0.09); border:1px solid rgba(232,59,59,0.35); border-radius:6px; padding:5px 9px; margin-top:5px; font-family:var(–mono); font-size:0.62rem; color:var(–accent); }
.max-warn.visible { display:block; }
.med-notes { background:rgba(245,166,35,0.05); border:1px solid rgba(245,166,35,0.18); border-radius:7px; padding:8px 10px; margin-top:9px; font-size:0.68rem; color:#c9a04a; line-height:1.55; }
.med-notes b { display:block; font-family:var(–mono); font-size:0.56rem; letter-spacing:1.5px; margin-bottom:3px; color:var(–yellow); }

/* WEIGHT CONVERTER PAGE */
.conv-hero { background:var(–surface); border:1px solid var(–border); border-radius:13px; padding:22px 18px 18px; margin-bottom:12px; text-align:center; position:relative; overflow:hidden; }
.conv-hero::before { content:’’; position:absolute; inset:0; background:radial-gradient(ellipse at 50% -10%,rgba(33,150,243,0.07) 0%,transparent 60%); pointer-events:none; }
.conv-lbl { font-family:var(–mono); font-size:0.58rem; color:var(–text-dim); letter-spacing:2px; margin-bottom:8px; }
.conv-big-inp { background:transparent; border:none; border-bottom:2px solid var(–blue); color:var(–blue); font-family:var(–mono); font-size:3.2rem; width:100%; text-align:center; outline:none; padding:5px 0; -webkit-appearance:none; letter-spacing:2px; }
.conv-big-unit { font-family:var(–display); font-size:0.85rem; font-weight:700; letter-spacing:3px; color:var(–text-dim); margin-top:4px; text-transform:uppercase; }
.conv-arrow { text-align:center; padding:7px; color:var(–text-muted); font-size:1.3rem; }
.conv-result { background:var(–blue-dim); border:1px solid rgba(33,150,243,0.22); border-radius:13px; padding:18px; text-align:center; margin-bottom:12px; }
.conv-result-lbl { font-family:var(–mono); font-size:0.58rem; color:var(–text-dim); letter-spacing:2px; margin-bottom:6px; }
.conv-result-val { font-family:var(–mono); font-size:3.2rem; color:var(–blue); letter-spacing:2px; line-height:1; text-shadow:0 0 18px rgba(33,150,243,0.4); }
.conv-result-unit { font-family:var(–display); font-weight:700; letter-spacing:3px; color:var(–text-dim); margin-top:4px; text-transform:uppercase; }

/* PEDS CARD */
.peds-card { background:var(–surface); border:1px solid var(–border); border-radius:13px; padding:15px; margin-bottom:13px; }
.peds-card h3 { font-family:var(–display); font-size:0.92rem; font-weight:700; letter-spacing:2px; text-transform:uppercase; color:var(–green); margin-bottom:11px; }
.peds-row2 { display:grid; grid-template-columns:1fr 1fr auto; gap:8px; align-items:end; }
.peds-field label { display:block; font-family:var(–mono); font-size:0.57rem; color:var(–text-dim); letter-spacing:1px; margin-bottom:4px; }
.peds-est-btn { background:rgba(0,200,150,0.1); border:1px solid rgba(0,200,150,0.3); border-radius:7px; color:var(–green); font-family:var(–mono); font-size:0.62rem; padding:10px 11px; letter-spacing:1px; cursor:pointer; white-space:nowrap; width:100%; }
.peds-est-result { background:rgba(0,200,150,0.06); border:1px solid rgba(0,200,150,0.22); border-radius:9px; padding:11px; margin-top:11px; display:none; }
.peds-est-result.show { display:block; }
.peds-est-grid { display:grid; grid-template-columns:1fr 1fr 1fr; gap:8px; text-align:center; }
.peds-est-item label { font-family:var(–mono); font-size:0.53rem; color:var(–text-dim); letter-spacing:1px; display:block; margin-bottom:3px; }
.peds-est-item span { font-family:var(–mono); font-size:0.88rem; color:var(–green); }
.apply-wt-btn { width:100%; margin-top:11px; background:rgba(0,200,150,0.08); border:1px solid rgba(0,200,150,0.32); border-radius:8px; color:var(–green); font-family:var(–mono); font-size:0.67rem; padding:10px; letter-spacing:1px; cursor:pointer; }

/* MODAL */
.modal-overlay { display:none; position:fixed; inset:0; background:rgba(0,0,0,0.88); z-index:800; backdrop-filter:blur(6px); overflow-y:auto; padding:18px 13px 40px; }
.modal-overlay.open { display:block; }
.modal-box { background:var(–surface); border:1px solid var(–border2); border-radius:15px; overflow:hidden; max-width:500px; margin:0 auto; }
.modal-header { background:var(–surface2); border-bottom:1px solid var(–border); padding:13px 15px; display:flex; align-items:center; justify-content:space-between; }
.modal-header h2 { font-family:var(–display); font-size:0.95rem; font-weight:800; letter-spacing:2px; text-transform:uppercase; color:var(–accent); }
.modal-close { background:transparent; border:none; color:var(–text-dim); font-size:1.2rem; cursor:pointer; padding:0 4px; line-height:1; }
.modal-body { padding:15px; }

/* PASSWORD */
.pw-gate { text-align:center; padding:8px 0 4px; }
.pw-gate p { font-size:0.72rem; color:var(–text-dim); margin-bottom:13px; line-height:1.5; }
.pw-inp { width:100%; background:var(–surface2); border:1px solid var(–border); border-radius:8px; padding:12px; color:var(–text); font-family:var(–mono); font-size:1rem; outline:none; text-align:center; letter-spacing:3px; margin-bottom:10px; -webkit-appearance:none; }
.pw-inp:focus { border-color:var(–accent); }
.pw-err { font-family:var(–mono); font-size:0.63rem; color:var(–accent); display:none; margin-bottom:7px; }

/* ADMIN */
.admin-panel { display:none; }
.admin-panel.show { display:block; }
.admin-tabs { display:flex; gap:4px; margin-bottom:13px; }
.admin-tab { flex:1; padding:8px; background:transparent; border:1px solid var(–border); border-radius:7px; color:var(–text-dim); font-family:var(–mono); font-size:0.63rem; letter-spacing:1px; cursor:pointer; }
.admin-tab.active { background:rgba(232,59,59,0.09); border-color:rgba(232,59,59,0.38); color:var(–accent); }
.admin-section { display:none; }
.admin-section.active { display:block; }

/* MED LIST */
.med-list-item { display:flex; align-items:center; gap:9px; padding:9px 11px; background:var(–surface2); border:1px solid var(–border); border-radius:8px; margin-bottom:6px; }
.med-list-dot { width:8px; height:8px; border-radius:50%; flex-shrink:0; }
.med-list-name { font-family:var(–display); font-size:0.92rem; font-weight:700; letter-spacing:0.5px; }
.med-list-class { font-family:var(–mono); font-size:0.57rem; color:var(–text-dim); }
.med-list-actions { display:flex; gap:5px; }
.med-list-btn { background:transparent; border:1px solid var(–border); border-radius:5px; color:var(–text-dim); font-size:0.72rem; padding:5px 8px; cursor:pointer; font-family:var(–mono); }
.med-list-btn.edit { border-color:rgba(33,150,243,0.38); color:var(–blue); }
.med-list-btn.del { border-color:rgba(232,59,59,0.28); color:var(–accent); }
.add-med-btn { width:100%; background:rgba(0,200,150,0.07); border:1px dashed rgba(0,200,150,0.32); border-radius:8px; color:var(–green); font-family:var(–mono); font-size:0.67rem; letter-spacing:1px; padding:11px; cursor:pointer; margin-top:4px; }

/* FORM */
.form-row { margin-bottom:11px; }
.form-row label { display:block; font-family:var(–mono); font-size:0.57rem; color:var(–text-dim); letter-spacing:1.5px; text-transform:uppercase; margin-bottom:4px; }
.form-inp, .form-sel, .form-textarea { width:100%; background:var(–surface2); border:1px solid var(–border); border-radius:7px; padding:9px 10px; color:var(–text); font-family:var(–mono); font-size:0.8rem; outline:none; -webkit-appearance:none; }
.form-inp:focus, .form-sel:focus, .form-textarea:focus { border-color:var(–blue); }
.form-textarea { min-height:65px; resize:vertical; font-size:0.72rem; line-height:1.5; }
.form-grid2 { display:grid; grid-template-columns:1fr 1fr; gap:9px; }
.conc-item { display:flex; gap:6px; align-items:center; margin-bottom:5px; }
.conc-item .form-inp { flex:1; }
.conc-del-btn { background:rgba(232,59,59,0.09); border:1px solid rgba(232,59,59,0.28); border-radius:5px; color:var(–accent); font-size:0.78rem; padding:8px 9px; cursor:pointer; flex-shrink:0; }
.add-conc-btn { background:transparent; border:1px dashed var(–border2); border-radius:6px; color:var(–text-dim); font-family:var(–mono); font-size:0.6rem; padding:7px 11px; cursor:pointer; letter-spacing:1px; width:100%; margin-bottom:9px; }
.dose-form-section { background:var(–surface2); border:1px solid var(–border); border-radius:8px; padding:11px; margin-bottom:9px; }
.dose-form-section h4 { font-family:var(–mono); font-size:0.6rem; color:var(–text-dim); letter-spacing:1.5px; text-transform:uppercase; margin-bottom:9px; }
.color-row { display:flex; gap:6px; flex-wrap:wrap; }
.color-opt { width:26px; height:26px; border-radius:50%; border:2px solid transparent; cursor:pointer; transition:transform 0.15s; }
.color-opt.selected { border-color:#fff; transform:scale(1.2); }
.save-btn { width:100%; background:var(–accent); border:none; border-radius:9px; color:#fff; font-family:var(–display); font-size:0.95rem; font-weight:800; letter-spacing:2px; text-transform:uppercase; padding:12px; cursor:pointer; margin-top:4px; box-shadow:0 4px 18px var(–accent-glow); }
.save-btn:active { opacity:0.85; }
.settings-row { display:flex; justify-content:space-between; align-items:center; padding:11px 0; border-bottom:1px solid var(–border); }
.settings-row:last-child { border-bottom:none; }
.settings-label { font-size:0.78rem; color:var(–text); }
.settings-sub { font-family:var(–mono); font-size:0.58rem; color:var(–text-dim); margin-top:2px; }
.settings-inp { background:var(–surface2); border:1px solid var(–border); border-radius:6px; padding:8px 9px; color:var(–text); font-family:var(–mono); font-size:0.72rem; outline:none; width:130px; text-align:right; -webkit-appearance:none; }
.empty-state { text-align:center; padding:28px 18px; color:var(–text-muted); font-family:var(–mono); font-size:0.67rem; letter-spacing:1px; }
.safe-bottom { height:20px; }
input[type=number]::-webkit-inner-spin-button, input[type=number]::-webkit-outer-spin-button { -webkit-appearance:none; }
::-webkit-scrollbar { width:3px; }
::-webkit-scrollbar-thumb { background:var(–border2); border-radius:2px; }
</style>

</head>
<body>

<div class="app-header">
  <div class="header-row">
    <div class="logo-cross">✚</div>
    <div class="logo-text">
      <h1>EMS Rx</h1>
      <p id="dept-display">FIELD DOSAGE CALCULATOR</p>
    </div>
    <div class="header-spacer"></div>
    <button class="admin-btn" onclick="openAdmin()">⚙ ADMIN</button>
  </div>
  <div class="nav-tabs">
    <button class="nav-tab active" onclick="showPage('dosing',this)">💊 Dosing</button>
    <button class="nav-tab" onclick="showPage('weight',this)">⚖ Weight</button>
    <button class="nav-tab" onclick="showPage('peds',this)">👶 Peds</button>
  </div>
</div>

<!-- ═══ DOSING PAGE ═══ -->

<div class="page active" id="page-dosing">
  <div class="weight-bar">
    <div class="wb-label">▸ PATIENT WEIGHT</div>
    <div class="wb-inputs">
      <div class="wb-field">
        <label>POUNDS (lbs)</label>
        <input type="number" class="field-inp" id="d-lbs" placeholder="—" inputmode="decimal" step="0.1" oninput="syncWeightFrom('lbs')">
      </div>
      <div class="wb-arrow">⇄</div>
      <div class="wb-field">
        <label>KILOGRAMS (kg)</label>
        <input type="number" class="field-inp kg-out" id="d-kg" placeholder="—" inputmode="decimal" step="0.1" oninput="syncWeightFrom('kg')">
      </div>
    </div>
  </div>
  <div class="disclaimer">
    <span style="flex-shrink:0;margin-top:1px;">⚕</span>
    <span class="disclaimer-text">Reference only. Always verify against your department's current SOPs and medical director protocols before administration.</span>
  </div>
  <div id="med-list-render"></div>
  <div class="safe-bottom"></div>
</div>

<!-- ═══ WEIGHT PAGE ═══ -->

<div class="page" id="page-weight">
  <div class="conv-hero">
    <div class="conv-lbl">▸ ENTER WEIGHT IN POUNDS</div>
    <input type="number" class="conv-big-inp" id="conv-lbs-big" placeholder="000" inputmode="decimal" step="0.1" oninput="syncConvBig()">
    <div class="conv-big-unit">Pounds / lbs</div>
  </div>
  <div class="conv-arrow">↓</div>
  <div class="conv-result">
    <div class="conv-result-lbl">▸ KILOGRAMS</div>
    <div class="conv-result-val" id="conv-kg-big">—</div>
    <div class="conv-result-unit">Kilograms / kg</div>
  </div>
  <div class="peds-card">
    <h3>📏 Pediatric Weight by Age</h3>
    <div class="peds-row2">
      <div class="peds-field"><label>Age</label><input type="number" class="field-inp" id="pw-age" placeholder="e.g. 4" inputmode="decimal" step="0.5" style="font-size:0.95rem;"></div>
      <div class="peds-field"><label>Unit</label><select class="field-inp" id="pw-unit" style="color:var(--text);font-size:0.82rem;"><option value="years">Years</option><option value="months">Months</option></select></div>
      <div class="peds-field"><label>&nbsp;</label><button class="peds-est-btn" onclick="estimatePW()">ESTIMATE</button></div>
    </div>
