function applyPedsWeight() {
  if (!pedsEstKg) return;
  patientKg = pedsEstKg;
  document.getElementById('d-kg').value = pedsEstKg;
  document.getElementById('d-lbs').value = +(pedsEstKg*2.2046).toFixed(1);
