function getBroselow(months) {
  for (const b of BROSELOW) if (months <= b.maxM) return b;
  return BROSELOW[BROSELOW.length-1];
}

function estimatePW() {
  const age = parseFloat(document.getElementById('pw-age').value);
  const unit = document.getElementById('pw-unit').value;
  if (isNaN(age)||age<=0) return;
  const b = getBroselow(unit==='years' ? age*12 : age);
  document.getElementById('pw-kg').textContent = b.kg+' kg';
  document.getElementById('pw-lbs').textContent = b.lbs+' lbs';
  document.getElementById('pw-color').textContent = b.color;
  document.getElementById('pw-result').classList.add('show');
}

function estimateP2() {
  const age = parseFloat(document.getElementById('p2-age').value);
  const unit = document.getElementById('p2-unit').value;
  if (isNaN(age)||age<=0) return;
  const b = getBroselow(unit==='years' ? age*12 : age);
  pedsEstKg = b.kg;
  document.getElementById('p2-kg').textContent = b.kg+' kg';
  document.getElementById('p2-lbs').textContent = b.lbs+' lbs';
