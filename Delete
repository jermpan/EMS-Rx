function buildBroselow() {
  const c = document.getElementById('broselow-table');
  c.innerHTML = BROSELOW.map((b,i) => {
    const prev = i>0?BROSELOW[i-1].maxM:0;
    const lbl = prev<12 ? `${prev}–${b.maxM} mo` : `${Math.round(prev/12)}–${Math.round(b.maxM/12)} yr`;
    return `<div class="dose-row"><span style="font-size:0.7rem;color:var(--text-dim);">${lbl}</span><span style="font-family:var(--mono);font-size:0.72rem;color:${BCOLOR[b.color]||'#fff'};margin-right:8px;">${b.color}</span><span style="font-family:var(--mono);font-size:0.72rem;color:var(--green);">${b.kg} kg / ${b.lbs} lbs</span></div>`;
